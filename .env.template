# NODIS — Environment configuration template
# Copy to .env and fill in your values:
#   cp .env.template .env
# IMPORTANT: Never commit .env — it is gitignored.

# -----------------------------------------------------------------------
# Snellius HPC (SURF)
# Used by scripts/sync_to_snellius.sh and scripts/sync_results_back.sh
# via sshpass -e (SSHPASS env var keeps password out of the process list)
# -----------------------------------------------------------------------
SNELLIUS_HOST=snellius.surf.nl
SNELLIUS_USER=your_username
SNELLIUS_PASSWORD=your_password
SNELLIUS_PORT=22
SNELLIUS_REMOTE_DIR=/home/your_username/NODIS

# -----------------------------------------------------------------------
# Snellius module environment — update if cluster software changes
# -----------------------------------------------------------------------
SNELLIUS_MODULE_ENV=2023
SNELLIUS_MODULE_R=R/4.3.2-gfbf-2023a

# -----------------------------------------------------------------------
# SLURM
# -----------------------------------------------------------------------
SNELLIUS_PARTITION=rome
