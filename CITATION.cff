  journal: "Journal of Open Source Software"
  authors:
    - family-names: Bumbuc
      given-names: Roland
      affiliation: "Amsterdam UMC, University of Amsterdam"
  title: "NODIS: NOdewise De-sparsified Inference Statistics for Gaussian Graphical Models in transcriptomics"
  year: 2026
