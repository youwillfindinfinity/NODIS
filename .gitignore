.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── Results & outputs ───────────────────────────────────────────────────────
# Local results (re-generatable from benchmarks)
results/
# Raw Snellius HPC outputs (167 MB+)
results_snellius_raw/
# Keep figures tracked (only 468 KB)
# figures/ is intentionally NOT ignored

# ── Data ─────────────────────────────────────────────────────────────────────
# Binary/large data files
*.pkl
*.npy
*.npz
*.h5
*.hdf5
*.parquet
*.feather
# Compressed archives (STRING DB files, etc.)
*.gz
*.zip
*.tar
*.tar.gz
*.tgz
# But keep small CSV/TSV data files (gold standards etc.) — not ignored

# ── SLURM / HPC ──────────────────────────────────────────────────────────────
slurm-*.out
*.slurm.out
logs/
scratch/

# ── Docs build ───────────────────────────────────────────────────────────────
docs/_build/
docs/api/
site/

# ── Sphinx ───────────────────────────────────────────────────────────────────
_build/
_static/
_templates/
